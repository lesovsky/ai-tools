# OpenClaw configuration
# Copy to ~/tools/openclaw/.env and fill in values (never commit .env to git)

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Gateway auth token (auto-generated by docker-setup.sh, or set manually)
# OPENCLAW_GATEWAY_TOKEN=

# Data directories (defaults are fine for local use)
# OPENCLAW_CONFIG_DIR=~/.openclaw

# Email IMAP (read-only access)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Gateway bind mode: lan (local network) or loopback (localhost only)
OPENCLAW_GATEWAY_BIND=lan

# Ports
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
